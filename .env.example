# Copy to .env (gitignored) and fill in. Never commit a real KEK.

# 32-byte key-encryption key, hex (64 chars) or base64. Generate with:
#   head -c32 /dev/urandom | xxd -p -c64
# or:
#   head -c32 /dev/urandom | base64
SIGNET_KEK=

# Optional overrides (defaults shown):
# SIGNET_BIND=0.0.0.0:8443
# SIGNET_DB=/data/signet.db
# SIGNET_TLS_CERT=/certs/server.pem
# SIGNET_TLS_KEY=/certs/server.key
# SIGNET_CLIENT_CA=/certs/ca.pem   # MUST be a dedicated Signet-only client CA
# SIGNET_KEY_BITS=2048
# Public-metadata namespace; signed metadata is <prefix>:<version_id>. Keep the
# default for FreedInk; a Deforum deployment sets e.g. deforum-ban. MUST match
# the client and verifier byte-for-byte or every signature fails closed. Only
# ASCII letters, digits, '-', '_', '.' (1-64); validated at startup.
# SIGNET_INFO_PREFIX=freedink-vote
# SIGNET_AUTO_CREATE_KEYS=true
# SIGNET_RL_PARTICIPANT_MAX=5
# SIGNET_RL_GLOBAL_MAX=1000
# SIGNET_RL_WINDOW_SECS=60
# RUST_LOG=info

# Client-identity pinning (audit M1/M3). Comma-separated cert CNs / DNS SANs.
# SIGNET_ALLOWED_CLIENT_IDS unset => ANY cert chaining to SIGNET_CLIENT_CA is
# accepted (warned at startup); set it in production. SIGNET_ADMIN_IDS unset =>
# /key/rotate is disabled for everyone (fail-closed).
# SIGNET_ALLOWED_CLIENT_IDS=freedink
# SIGNET_ADMIN_IDS=signet-admin

# Async keygen + /key* rate limiting (audit H1).
# SIGNET_KEYGEN_MAX_CONCURRENT=2
# SIGNET_RL_KEY_IDENTITY_MAX=10
# SIGNET_RL_KEY_GLOBAL_MAX=100
